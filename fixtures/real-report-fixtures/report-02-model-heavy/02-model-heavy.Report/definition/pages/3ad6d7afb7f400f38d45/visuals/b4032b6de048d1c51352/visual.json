{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "trend-chart",
  "position": {
    "x": 20,
    "y": 140,
    "z": 5000,
    "height": 300,
    "width": 620,
    "tabOrder": 4
  },
  "visual": {
    "visualType": "lineClusteredColumnComboChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Date"
                    }
                  },
                  "Property": "YearMonth"
                }
              },
              "queryRef": "Date.YearMonth",
              "nativeQueryRef": "YearMonth",
              "active": true
            }
          ]
        },
        "Rows": {
          "projections": []
        },
        "Series": {
          "projections": []
        },
        "Tooltips": {
          "projections": []
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "GL_Actuals"
                    }
                  },
                  "Property": "Actual Amount"
                }
              },
              "queryRef": "GL_Actuals.Actual Amount",
              "nativeQueryRef": "Actual Amount"
            }
          ]
        },
        "Y2": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Budget"
                    }
                  },
                  "Property": "Budget Amount"
                }
              },
              "queryRef": "Budget.Budget Amount",
              "nativeQueryRef": "Budget Amount"
            }
          ]
        }
      }
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Actual vs Budget Trend'"
                }
              }
            }
          }
        }
      ]
    }
  }
}