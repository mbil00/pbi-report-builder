{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "dept-bar",
  "position": {
    "x": 20,
    "y": 80,
    "z": 1000,
    "height": 340,
    "width": 500,
    "tabOrder": 0
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Department"
                    }
                  },
                  "Property": "DepartmentName"
                }
              },
              "queryRef": "Department.DepartmentName",
              "nativeQueryRef": "DepartmentName",
              "active": true
            }
          ]
        },
        "Gradient": {
          "projections": []
        },
        "Rows": {
          "projections": []
        },
        "Series": {
          "projections": []
        },
        "Tooltips": {
          "projections": []
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "GL_Actuals"
                    }
                  },
                  "Property": "Actual Amount"
                }
              },
              "queryRef": "GL_Actuals.Actual Amount",
              "nativeQueryRef": "Actual Amount"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Column": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "{'GL_Actuals"
                  }
                },
                "Property": "Actual Amount': 'descending'}"
              }
            },
            "direction": "Descending"
          }
        ]
      }
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Actual by Department'"
                }
              }
            }
          }
        }
      ]
    }
  }
}