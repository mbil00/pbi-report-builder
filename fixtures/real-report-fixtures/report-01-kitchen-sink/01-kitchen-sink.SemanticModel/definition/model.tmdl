model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["Channel","Customer","Date","Product","Promotion","Sales","Store","Targets"]

ref table Channel
ref table Product
ref table Sales
ref table Customer
ref table Date
ref table Promotion
ref table Store
ref table Targets
ref table _Measures

ref cultureInfo en-US

