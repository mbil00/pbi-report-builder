{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "qaChart",
  "position": {
    "x": 16,
    "y": 90,
    "z": 2000,
    "height": 400,
    "width": 600,
    "tabOrder": 1
  },
  "visual": {
    "visualType": "clusteredColumnChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Product"
                    }
                  },
                  "Property": "Category"
                }
              },
              "queryRef": "Product.Category",
              "nativeQueryRef": "Category",
              "active": true
            }
          ]
        },
        "Gradient": {
          "projections": []
        },
        "Rows": {
          "projections": []
        },
        "Series": {
          "projections": []
        },
        "Tooltips": {
          "projections": []
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Revenue"
                }
              },
              "queryRef": "Measures.Revenue",
              "nativeQueryRef": "Revenue"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Column": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "_Measures"
                  }
                },
                "Property": "Revenue"
              }
            },
            "direction": "Descending"
          }
        ]
      }
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Revenue by Category (QA)'"
                }
              }
            }
          }
        }
      ],
      "border": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "color": {
              "solid": {
                "color": {
                  "expr": {
                    "Literal": {
                      "Value": "'#E0E0E0'"
                    }
                  }
                }
              }
            }
          }
        }
      ],
      "background": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "color": {
              "solid": {
                "color": {
                  "expr": {
                    "Literal": {
                      "Value": "'#FFFFFF'"
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  },
  "filterConfig": {
    "filters": []
  }
}
