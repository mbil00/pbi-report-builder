{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "tt-variance-bar",
  "position": {
    "x": 10,
    "y": 80,
    "width": 290,
    "height": 80,
    "z": 3000,
    "tabOrder": 2
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Department"
                    }
                  },
                  "Property": "DepartmentName"
                }
              },
              "queryRef": "Department.DepartmentName",
              "nativeQueryRef": "DepartmentName"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Forecast"
                    }
                  },
                  "Property": "Actual vs Budget"
                }
              },
              "queryRef": "Forecast.Actual vs Budget",
              "nativeQueryRef": "Actual vs Budget"
            }
          ]
        },
        "Series": {
          "projections": []
        },
        "Tooltips": {
          "projections": []
        },
        "Gradient": {
          "projections": []
        },
        "Rows": {
          "projections": []
        }
      }
    },
    "objects": {},
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Variance'"
                }
              }
            }
          }
        }
      ]
    }
  }
}
