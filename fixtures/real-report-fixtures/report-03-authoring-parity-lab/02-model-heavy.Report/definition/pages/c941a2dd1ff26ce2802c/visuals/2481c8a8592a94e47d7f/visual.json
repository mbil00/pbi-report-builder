{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "tt-sparkline",
  "position": {
    "x": 10,
    "y": 170,
    "width": 290,
    "height": 60,
    "z": 4000,
    "tabOrder": 3
  },
  "visual": {
    "visualType": "lineChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Date"
                    }
                  },
                  "Property": "MonthName"
                }
              },
              "queryRef": "Date.MonthName",
              "nativeQueryRef": "MonthName"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "GL_Actuals"
                    }
                  },
                  "Property": "Actual Amount"
                }
              },
              "queryRef": "GL_Actuals.Actual Amount",
              "nativeQueryRef": "Actual Amount"
            }
          ]
        },
        "Series": {
          "projections": []
        },
        "Tooltips": {
          "projections": []
        },
        "Y2": {
          "projections": []
        },
        "Rows": {
          "projections": []
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Column": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "Date"
                  }
                },
                "Property": "MonthNumber"
              }
            },
            "direction": "Ascending"
          }
        ],
        "isDefaultSort": false
      }
    },
    "objects": {},
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Trend'"
                }
              }
            }
          }
        }
      ]
    }
  }
}
